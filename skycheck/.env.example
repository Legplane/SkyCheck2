# ─────────────────────────────────────────────────────────────────────
# SkyCheck Frontend — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────

# Backend API base URL
# ── Local browser testing (HTTP is fine on localhost):
VITE_API_BASE_URL=http://localhost:3000

# ── Phone / LAN testing WITH HTTPS (required for GPS on phone):
#    Step 1: Start backend normally:       cd skycheck-backend && npm run dev
#    Step 2: Start frontend with HTTPS:
#              Mac/Linux: npm run dev:https
#              Windows:   npm run dev:https:win
#    Step 3: Find your PC's LAN IP:
#              Windows: ipconfig  (look for IPv4 Address)
#              Mac:     ifconfig | grep "inet "
#    Step 4: On your phone open: https://192.168.x.x:5173
#    Step 5: Tap "Advanced" → "Proceed anyway" to accept the self-signed cert
#    Step 6: GPS will now work on your phone!
#
#    IMPORTANT: When using HTTPS mode, the Vite proxy (/api → localhost:3000)
#    still works — you do NOT need to change VITE_API_BASE_URL for LAN testing.
#    Only change it if you're bypassing the Vite proxy entirely.
#
# ── Production / ngrok:
#    VITE_API_BASE_URL=https://your-backend.railway.app

# MapTiler API Key — Free at https://cloud.maptiler.com (100k req/month, no CC)
# Used for map tiles in Add Route screen. Leave blank to use OpenStreetMap.
VITE_MAPTILER_KEY=your_maptiler_key_here

# Google Sign-In — Web client ID (same value as backend GOOGLE_CLIENT_ID)
# Console: APIs & Services → Credentials → OAuth 2.0 Client IDs → Web application
# Authorized JavaScript origins: http://localhost:5173 (+ your HTTPS dev/prod origins)
VITE_GOOGLE_CLIENT_ID=

# Firebase Auth
# Firebase Console -> Project settings -> Your apps -> Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
